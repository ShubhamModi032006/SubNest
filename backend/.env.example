# Database
DB_URL=postgresql://username:password@localhost:5432/subnest

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Email (Nodemailer)
EMAIL_USER=your_email@gmail.com
